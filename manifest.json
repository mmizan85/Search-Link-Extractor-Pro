{
  "manifest_version": 3,
  "name": "Search Link Extractor & Serializer",
  "short_name": "Link Extractor",
  "version": "1.0.0",
  "author": "Mohammed Mizanur Rahman",
  "description": "Extract, filter, and export Google Search result links, titles, and snippets across multiple pages with smart deduplication and anti-bot pacing.",
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Search Link Extractor"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://www.google.com/search*",
    "https://www.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "minimum_chrome_version": "110"
}
